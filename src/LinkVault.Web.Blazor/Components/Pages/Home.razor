@page "/"

<PageTitle>Home | LinkVault </PageTitle>

<div class="min-h-0 h-full grow">
    <div class="flex min-h-full flex-col justify-center">
        <div class="w-full max-w-3xl mx-auto text-center space-y-8">
            <div class="space-y-4">
                
                <BbTypographyH1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">
                    LinkVault
                </BbTypographyH1>
                <BbTypographyLead class="mx-auto max-w-2xl text-muted-foreground">
                    A Simple URL Shortening Service.
                </BbTypographyLead>

                <BbCard>
                    <BbCardHeader>
                        <BbCardTitle>Shorten a Link</BbCardTitle>
                        <BbCardDescription>Transform your long URL into a short link here.</BbCardDescription>
                    </BbCardHeader>
                    <BbCardContent>
                        <div class="flex flex-col sm:flex-row gap-3">
                            <BbInput @bind-Value="inputUrl" Type="InputType.Url" placeholder="Paste long url here" class="flex-1" />
                            <BbButton @onclick="ShortenUrlAsync">Shorten</BbButton>
                        </div>
                    </BbCardContent>
                    <BbCardFooter>
                        <BbTypographyMuted>LinkVault is a free service to shorten URLs into short links.</BbTypographyMuted>
                    </BbCardFooter>
                </BbCard>
                
                @if (!string.IsNullOrEmpty(shortCode))
                {
                    <BbCard>
                        <BbCardHeader>
                            <BbCardTitle>Your Shortened Link</BbCardTitle>
                        </BbCardHeader>
                        <BbCardContent>
                            <div class="space-y-4">
                                <div class="flex items-center justify-between gap-2">
                                    <div>
                                        <BbTypographyMuted>Short URL:</BbTypographyMuted>
                                        <BbLabel>@ShortCodeUrl</BbLabel>
                                    </div>
                                    <div class="flex items-center justify-center gap-2">
                                        <BbButton Size="ButtonSize.IconSmall" Href="@ShortCodeUrl" Target="_blank" AriaLabel="Visit">
                                            <LucideIcon Name="external-link" />
                                        </BbButton>
                                        @if (qrCode is not null)
                                        {
                                            <div class="flex flex-col items-center gap-2">
                                                <img src="@qrCode.Src" alt="QR Code" class="w-24 h-24 border rounded-lg" />
                                            </div>
                                        }
                                        <BbButton Size="ButtonSize.IconSmall" @onclick="@(() => DownloadQrCodeAsync(qrCode))" Disabled="@(qrCode is null)" AriaLabel="Download">
                                            <LucideIcon Name="download" />
                                        </BbButton>
                                        <BbButton Size="ButtonSize.IconSmall" @onclick="@(() => CopyShortUrlAsync(ShortCodeUrl))" AriaLabel="Copy">
                                            <LucideIcon Name="copy" />
                                        </BbButton>
                                    </div>
                                </div>
                            </div>
                        </BbCardContent>
                    </BbCard>
                }

            </div>
        </div>
    </div>
</div>

@code
{
    private sealed record QrCodeDto(string FileName, string MediaType, byte[] ImageBytes)
    {
        public string Src => $"data:{MediaType};base64,{Base64}";
        public string Base64 => Convert.ToBase64String(ImageBytes);
    }

    private string inputUrl = string.Empty;
    private string shortCode = string.Empty;
    private QrCodeDto? qrCode;

    private string ShortCodeUrl => string.IsNullOrEmpty(shortCode) ? string.Empty : $"{Navigation.BaseUri}{shortCode}";

    private async Task ShortenUrlAsync()
    {
        var request = new ShortenUrlRequest(inputUrl);
        var response = await ApiClient.ShortenUrlAsync(request);
        shortCode = response.ShortCode;

        await InvokeAsync(StateHasChanged);

        await GenerateQrCodeAsync();
    }

    private async Task GenerateQrCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(shortCode))
        {
            return;
        }

        var request = new GenerateQrCodeRequest(shortCode, Navigation.BaseUri);
        var response = await ApiClient.GenerateQrCodeAsync(request);
        qrCode = new(response.FileName, response.MediaType, response.ImageBytes);
    }

    private async Task CopyShortUrlAsync(string shortUrl)
    {
        try
        {
            await Clipboard.WriteTextAsync(shortUrl);
        }   
        catch (Exception)
        {
            Console.WriteLine("Cannot write to the clipboard.");
        }
    }

    private async Task DownloadQrCodeAsync(QrCodeDto? qrCode)
    {
        if (qrCode is null)
        {
            return;
        }

        await Download.DownloadFileAsync(qrCode.FileName, qrCode.ImageBytes);
    }
}
